<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
<t t-name="hatchery_management.HatcheryDateRangePicker">
<div class="hdrp-wrapper" t-ref="root">

    <!-- Trigger input -->
    <div class="hdrp-trigger" t-on-click="(e) => this.toggle(e)">
        <i class="fa fa-calendar hdrp-icon"/>
        <span class="hdrp-display" t-esc="displayText"/>
        <i class="fa fa-times hdrp-clear"
           t-if="state.startDate"
           t-on-click="(e) => this.clearDates(e)"/>
    </div>

    <!-- Dropdown -->
    <div class="hdrp-dropdown" t-if="state.isOpen" t-on-click.stop="">
        <div class="hdrp-body">

            <!-- Quick options -->
            <div class="hdrp-quick">
                <t t-foreach="quickOptions" t-as="opt" t-key="opt.key">
                    <div t-att-class="'hdrp-quick-item' + (state.activeQuick === opt.key ? ' hdrp-quick-active' : '')"
                         t-on-click="() => this.setQuick(opt.key)"
                         t-esc="opt.label"/>
                </t>
            </div>

            <!-- Vertical separator -->
            <div class="hdrp-vsep"/>

            <!-- Two calendars -->
            <div class="hdrp-cals">

                <!-- Calendar 1 -->
                <div class="hdrp-cal">
                    <div class="hdrp-cal-hdr">
                        <button class="hdrp-nav" t-on-click="() => this.prevMonth()">&#8249;</button>
                        <span class="hdrp-month-lbl" t-esc="monthLabel1"/>
                        <span style="width:28px"/>
                    </div>
                    <div class="hdrp-wdays">
                        <t t-foreach="weekdays" t-as="wd" t-key="wd">
                            <div t-esc="wd"/>
                        </t>
                    </div>
                    <div class="hdrp-grid">
                        <t t-foreach="days1" t-as="day" t-key="day.date.getTime()">
                            <div t-att-class="this.dayClass(day)"
                                 t-on-click="() => this.clickDay(day.date)"
                                 t-on-mouseenter="() => this.hoverDay(day.date)"
                                 t-esc="day.date.getDate()"/>
                        </t>
                    </div>
                </div>

                <!-- Separator -->
                <div class="hdrp-calsep"/>

                <!-- Calendar 2 -->
                <div class="hdrp-cal">
                    <div class="hdrp-cal-hdr">
                        <span style="width:28px"/>
                        <span class="hdrp-month-lbl" t-esc="monthLabel2"/>
                        <button class="hdrp-nav" t-on-click="() => this.nextMonth()">&#8250;</button>
                    </div>
                    <div class="hdrp-wdays">
                        <t t-foreach="weekdays" t-as="wd" t-key="wd">
                            <div t-esc="wd"/>
                        </t>
                    </div>
                    <div class="hdrp-grid">
                        <t t-foreach="days2" t-as="day" t-key="day.date.getTime()">
                            <div t-att-class="this.dayClass(day)"
                                 t-on-click="() => this.clickDay(day.date)"
                                 t-on-mouseenter="() => this.hoverDay(day.date)"
                                 t-esc="day.date.getDate()"/>
                        </t>
                    </div>
                </div>

            </div>
        </div>

        <!-- Footer -->
        <div class="hdrp-footer">
            <button class="hdrp-btn-cancel" t-on-click="() => this.cancel()">Bekor qilish</button>
            <button class="hdrp-btn-apply" t-on-click="() => this.apply()">Qoʻllash</button>
        </div>
    </div>

</div>
</t>
</templates>
