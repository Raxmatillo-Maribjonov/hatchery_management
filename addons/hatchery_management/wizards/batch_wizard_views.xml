<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_batch_wizard_form" model="ir.ui.view">
        <field name="name">hatchery.batch.wizard.form</field>
        <field name="model">hatchery.batch.wizard</field>
        <field name="arch" type="xml">
            <form string="Yangi Partiya Qo`shish">
                <sheet>
                    <div class="oe_title">
                        <h2>Yangi Inkubatsiya Partiyasi</h2>
                    </div>

                    <!-- 1-qadam -->
                    <group string="1. Asosiy ma`lumotlar">
                        <group>
                            <field name="incubator_id"/>
                            <field name="zapravka_date"/>
                        </group>
                        <group>
                        </group>
                    </group>

                    <!-- 2-qadam: sort qatorlari -->
                    <group string="2. Sortlar bo`yicha taqsimot">
                        <field name="line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="norm_id"/>
                                <field name="egg_count"/>
                                <field name="hatch_rate" readonly="1"/>
                                <field name="expected_chick_count" readonly="1"/>
                            </list>
                        </field>
                    </group>

                    <!-- Jami preview -->
                    <group string="Jami prognoz" invisible="not line_ids">
                        <group>
                            <field name="total_egg_count" readonly="1"/>
                            <field name="total_expected_chick_count" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_create_batch" string="Partiyani yaratish"
                            type="object" class="btn-primary"/>
                    <button string="Bekor qilish" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_batch_wizard" model="ir.actions.act_window">
        <field name="name">Yangi Partiya</field>
        <field name="res_model">hatchery.batch.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
