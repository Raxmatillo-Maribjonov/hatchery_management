<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- KANBAN -->
    <record id="view_reservation_kanban" model="ir.ui.view">
        <field name="name">hatchery.reservation.kanban</field>
        <field name="model">hatchery.reservation</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="client_name"/>
                <field name="client_phone"/>
                <field name="chick_count"/>
                <field name="state"/>
                <field name="batch_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click p-0">
                            <div t-attf-style="
                                background: #{record.state.raw_value == 'confirmed' ? '#007bff' :
                                             record.state.raw_value == 'waiting' ? '#ffc107' :
                                             record.state.raw_value == 'delivered' ? '#28a745' : '#dc3545'};
                                color: white; padding: 8px 12px; border-radius: 6px 6px 0 0;">
                                <strong><t t-esc="record.client_name.value"/></strong>
                            </div>
                            <div class="p-3">
                                <div class="row text-center mb-2">
                                    <div class="col-12">
                                        <div class="text-muted small">Jo`ja soni</div>
                                        <div class="fs-4 fw-bold text-success">
                                            <t t-esc="record.chick_count.value"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="text-muted small text-center">
                                    <i class="fa fa-phone me-1"/>
                                    <t t-esc="record.client_phone.value"/>
                                </div>
                                <div class="text-muted small text-center mt-1">
                                    <i class="fa fa-cube me-1"/>
                                    <t t-esc="record.batch_id.value"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- LIST -->
    <record id="view_reservation_list" model="ir.ui.view">
        <field name="name">hatchery.reservation.list</field>
        <field name="model">hatchery.reservation</field>
        <field name="arch" type="xml">
            <list string="Rezervlar"
                  decoration-success="state == 'delivered'"
                  decoration-warning="state == 'waiting'"
                  decoration-info="state == 'confirmed'"
                  decoration-danger="state == 'cancelled'">
                <field name="name"/>
                <field name="batch_id"/>
                <field name="client_name"/>
                <field name="client_phone"/>
                <field name="chick_count"/>
                <field name="reservation_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_reservation_form" model="ir.ui.view">
        <field name="name">hatchery.reservation.form</field>
        <field name="model">hatchery.reservation</field>
        <field name="arch" type="xml">
            <form string="Rezerv">
                <header>
                    <button name="action_set_waiting" string="Navbatga qo`yish"
                            type="object" invisible="state != 'confirmed'"/>
                    <button name="action_deliver" string="Berildi"
                            type="object" invisible="state not in ('confirmed','waiting')"
                            class="btn-success"/>
                    <button name="action_cancel" string="Bekor qilish"
                            type="object" invisible="state in ('delivered','cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="confirmed,waiting,delivered"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" class="text-primary"/></h1>
                    </div>

                    <!-- KPI -->
                    <div class="row mb-4">
                        <div class="col-4">
                            <div class="card text-center border-success shadow-sm">
                                <div class="card-body py-3">
                                    <div class="text-muted small fw-bold text-uppercase">Jo`ja soni</div>
                                    <div class="fs-2 fw-bold text-success">
                                        <field name="chick_count" readonly="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="card text-center border-primary shadow-sm">
                                <div class="card-body py-3">
                                    <div class="text-muted small fw-bold text-uppercase">Partiya</div>
                                    <div class="fw-bold text-primary">
                                        <field name="batch_id" readonly="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="card text-center border-secondary shadow-sm">
                                <div class="card-body py-3">
                                    <div class="text-muted small fw-bold text-uppercase">Sana</div>
                                    <div class="fw-bold">
                                        <field name="reservation_date" readonly="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-6">
                            <div class="card shadow-sm">
                                <div class="card-header bg-primary text-white fw-bold">
                                    <i class="fa fa-user me-2"/> Mijoz ma`lumotlari
                                </div>
                                <div class="card-body">
                                    <group col="1">
                                        <field name="client_name"/>
                                        <field name="client_phone"/>
                                    </group>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="card shadow-sm">
                                <div class="card-header bg-success text-white fw-bold">
                                    <i class="fa fa-bookmark me-2"/> Rezerv ma`lumotlari
                                </div>
                                <div class="card-body">
                                    <group col="1">
                                        <field name="batch_id"/>
                                        <field name="chick_count"/>
                                        <field name="reservation_date"/>
                                    </group>
                                </div>
                            </div>
                        </div>
                    </div>

                    <field name="notes" placeholder="Izoh..." class="mt-3"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_reservation" model="ir.actions.act_window">
        <field name="name">Rezervlar</field>
        <field name="res_model">hatchery.reservation</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>
